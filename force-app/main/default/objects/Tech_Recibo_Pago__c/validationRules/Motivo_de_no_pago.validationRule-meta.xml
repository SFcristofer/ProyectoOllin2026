<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Motivo_de_no_pago</fullName>
    <active>true</active>
    <description>Validar motivo de no pago</description>
    <errorConditionFormula>AND(
    ISPICKVAL(Estado__c, &quot;No Pagado&quot;),
    ISBLANK(TEXT(Motivo_No_Pago__c))
)</errorConditionFormula>
    <errorMessage>Para marcar un recibo como No Pagado debes capturar el motivo.</errorMessage>
</ValidationRule>
