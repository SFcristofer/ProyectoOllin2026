<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Endoso_Monto_Positivo</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT(ISBLANK(Nuevo_Monto_Afianzado__c)), Nuevo_Monto_Afianzado__c &lt;= 0)</errorConditionFormula>
    <errorMessage>El nuevo monto afianzado debe ser mayor a cero.</errorMessage>
</ValidationRule>
